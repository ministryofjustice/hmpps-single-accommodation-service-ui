{% extends "pages/duty-to-refer/layout.njk" %}

{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{% block formContent %}
    {{ govukRadios({
        id: "outcomeStatus",
        name: "outcomeStatus",
        fieldset: {
            legend: {
                text: "Has the local authority agreed to support this person with housing?",
                classes: "govuk-fieldset__legend--s"
            }
        },
        items: [
            {
                value: "ACCEPTED",
                text: "Yes"
            },
            {
                value: "NOT_ACCEPTED",
                text: "No"
            }
        ],
        errorMessage: errors.outcomeStatus
    }) }}
{% endblock %}
