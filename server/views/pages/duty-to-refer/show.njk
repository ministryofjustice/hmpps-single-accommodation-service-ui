{% extends "partials/layout.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "components/macros/caseDetails.njk" import caseDetails %}

{% set pageTitle = "Duty to Refer (DTR) " + applicationName %}
{% set mainClasses = "sas-profile-page" %}

{% block beforeContent %}
  {{
    govukBreadcrumbs({
      items: [
        {
          text: "Case List",
          href: "/"
        },
        {
          text: caseData.name + "'s profile",
          href: paths.cases.show({ crn: caseData.crn })
        }
      ]
    })
  }}
  {{ super() }}
{% endblock %}

{% block content %}
    {{ caseDetails(caseData, assignedTo) }}
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds-from-desktop">
            <h1 class="govuk-heading-l govuk-!-margin-top-4">Duty to Refer (DTR)</h1>
        </div>
    </div>
    <div class="govuk-grid-row">
        <section class="govuk-grid-column-two-thirds-from-desktop">
            {% if outcomeDetailRows.length %}
                <h2 class="govuk-heading-m">Outcome details</h2>
                {{
                    govukSummaryList({
                    rows: outcomeDetailRows
                    })
                }}
                {{ govukButton({
                    text: "Edit outcome details",
                    classes: "govuk-button--secondary",
                    href: paths.dutyToRefer.outcome({ crn: crn }) + '?flow=edit',
                    preventDoubleClick: true
                }) }}
            {% endif %}

            <h2 class="govuk-heading-m">Submission details</h2>
            {{ govukSummaryList({
                rows: submissionDetailRows
            }) }}
            {% if status == "NOT_STARTED" %}
                {{ govukButton({
                    text: "Add submission details",
                    href: paths.dutyToRefer.guidance({ crn: crn }),
                    preventDoubleClick: true
                }) }}
            {% else %}
                {{ govukButton({
                    text: "Edit submission details",
                    classes: "govuk-button--secondary",
                    href: paths.dutyToRefer.submission({ crn: crn }) + '?flow=edit',
                    preventDoubleClick: true
                }) }}
                {% if not outcomeDetailRows.length %}
                    <h2 class="govuk-heading-m">Outcome details</h2>
                    <p>No details about the outcome have been added.</p>
                    {{ govukButton({
                        text: "Add outcome",
                        href: paths.dutyToRefer.outcome({ crn: crn }),
                        preventDoubleClick: true
                    }) }}
                {% endif %}
            {% endif %}
        </section>
    </div>
{% endblock %}