{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}
{% from "components/macros/caseDetails.njk" import caseDetails %}
{% from "components/macros/statusCard.njk" import statusCard %}
{% from "components/macros/accommodationCard.njk" import accommodationCard %}
{% from "components/macros/noFixedAbodeAlert.njk" import noFixedAbodeAlert %}
{% from "components/macros/referralHistoryTable.njk" import referralHistoryTable %}
{% from "components/macros/accommodationHistoryTable.njk" import accommodationHistoryTable %}
{% from "components/macros/apiErrors/summary.njk" import apiErrorsSummary %}
{% from "components/macros/apiErrors/inset.njk" import apiErrorInset %}

{% extends "partials/layout.njk" %}

{% set pageTitle = "Profile" %}
{% set mainClasses = "sas-profile-page" %}

{% block containerStart %}
  {{
    govukBreadcrumbs({
        items: [
            {
                text: "Case list",
                href: "/"
            }
        ]
    })
  }}
  {{ super() }}
{% endblock %}

{% block content %}
  {% if upstreamFailures | length %}
    {{ apiErrorsSummary() }}
  {% endif %}

  {{ caseDetails(caseData, assignedTo) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds-from-desktop">
      <h2 class="govuk-heading-l govuk-!-margin-top-2">Arrange next accommodation</h2>
    </div>
  </div>

  <div class="govuk-grid-row">
    <section class="govuk-grid-column-one-third-from-desktop govuk-grid-column-right-from-desktop">
      <h2 class="govuk-visually-hidden">Current situation</h2>
      {{ noFixedAbodeAlert(noFixedAbode) }}

      <section class="sas-card sas-card--block">
        <h3 class="govuk-heading-m">Next actions</h3>

        {% if 'eligibility' in upstreamFailures %}
          {{  apiErrorInset() }}
        {% else %}
          {% if nextActions | length %}
            <ul class="govuk-list govuk-list--bullet">
              {% for action in nextActions %}
                <li>{{ action | safe }}</li>
              {% endfor %}
            </ul>
          {% endif %}
        {% endif %}
      </section>

      {{ accommodationCard(currentAccommodationCard) }}
      {{ accommodationCard(nextAccommodationCard) }}
    </section>

    <div class="govuk-grid-column-two-thirds-from-desktop">
      <section>
        <h2 class="govuk-visually-hidden">Accommodation referrals</h2>
        {% if 'eligibility' in upstreamFailures %}
          {{ apiErrorInset() }}
        {% else %}
          {% for card in eligibilityCards %}
            {{ statusCard(card) }}
          {% endfor %}
        {% endif %}
      </section>

      <section class="govuk-!-margin-top-8">
        <header class="sas-section__header">
          <h2 class="govuk-heading-l govuk-!-margin-bottom-4">Proposed addresses</h2>
          <a
            href="{{ paths.proposedAddresses.start({ crn: caseData.crn }) }}"
            class="govuk-link govuk-link--no-visited-state govuk-body"
            >Add a proposed address</a
          >
        </header>

        {% if proposedAddresses | length %}
          {% for card in proposedAddresses %}
            {{ statusCard(card) }}
          {% endfor %}
        {% else %}
          <p>No proposed addresses have been added.</p>
        {% endif %}

        {% if failedChecksAddresses | length %}
          <h3 class="govuk-heading-m govuk-!-margin-top-5">Addresses that failed checks</h3>
          {% for card in failedChecksAddresses %}
            {{ statusCard(card) }}
          {% endfor %}
        {% endif %}
      </section>
    </div>
  </div>

  <h2 class="govuk-heading-l govuk-!-margin-top-6">History</h2>

  <section>
    {{ referralHistoryTable({ rows: referralHistoryRows, hasApiError: 'referralHistory' in upstreamFailures }) }}
  </section>

  <section>
    {{ accommodationHistoryTable({ rows: accommodationHistoryRows, hasApiError: 'accommodationHistory' in upstreamFailures }) }}
  </section>
{% endblock %}
