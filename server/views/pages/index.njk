{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% extends "partials/layout.njk" %}

{% set pageTitle = applicationName + " - Home" %}
{% set mainClasses = "govuk-body" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <h1 class="govuk-heading-xl">Accommodation service</h1>
    </div>
  </div>

  <div class="govuk-tabs">
    <ul class="govuk-tabs__list">
      {% for tab in tabs %}
        <li class="govuk-tabs__list-item {% if tab.selected %}govuk-tabs__list-item--selected{% endif %}">
          <a class="govuk-tabs__tab" href="{{ tab.href }}">{{ tab.text }}</a>
        </li>
      {% endfor %}
    </ul>

    <div class="govuk-tabs__panel">
      <h2 class="govuk-heading-l">{{ 'Housing support needed' if peopleType === 'nfarisk' else 'Settled housing secured' }}</h2>

      <form method="get" class="govuk-!-margin-bottom-8">
        <input type="hidden" name="peopleType" value="{{ peopleType }}" />

        {# FIXME -- Experimental Easter Egg #}
        <input type="hidden" name="crns" value="{{ query.crns }}" />
        <div class="govuk-grid-row">
          <div class="govuk-grid-column-one-half">
            {{
              govukInput({
                label: { text: 'Search by name, CRN or prison number' },
                name: 'searchTerm',
                value: query.searchTerm
              })
            }}
          </div>
        </div>
        <div class="govuk-grid-row">
          <div class="govuk-grid-column-one-quarter">
            {{
              govukSelect({
                label: {
                  text: 'Assigned to'
                },
                name: 'assignedTo',
                value: query.assignedTo,
                items: assignedToOptions,
              classes: 'govuk-!-width-full'})
            }}
          </div>

          <div class="govuk-grid-column-one-quarter">
            {{
              govukSelect({
                  label: {
                    text: 'RoSH'
                  },
                  name: 'riskLevel',
                  value: query.riskLevel,
                  items: riskLevelOptions,
                classes: 'govuk-!-width-full'
              })
            }}
          </div>
        </div>
        <div class="govuk-grid-row">
          <div class="govuk-grid-column-two-thirds">
            <div class="sas-filters__actions">{{ govukButton({ text: 'Apply filters' }) }}</div>
          </div>
        </div>
      </form>
      {% if filters and filters.length %}
        <div class="sas-filters__summary">
          <h2 id="case-list-summary" class="govuk-heading-m">Showing {{ resultsSummary }}</h2>
          <p class="govuk-!-margin-bottom-1">Filters applied:</p>
          <ul class="moj-filter-tags">
            {% for filter in filters %}
              <li>
                <a class="moj-filter__tag" href="{{ filter.href }}">
                  <span class="govuk-visually-hidden">Remove this filter</span> {{ filter.text }}
                </a>
              </li>
            {% endfor %}
          </ul>
          <p class="govuk-!-margin-bottom-1">
            <a class="govuk-link govuk-link--no-visited-state" href="/">Clear filters</a>
          </p>
        </div>
      {% else %}
        <h2 id="case-list-summary" class="govuk-heading-m">{{ resultsSummary }}</h2>
      {% endif %}

      {{
        govukTable({
          attributes: {
            'aria-labelledby': 'case-list-summary'
          },
          head: [
            { text: "Person" },
            { text: "Current accommodation" },
            { text: "Next accommodation" },
            { text: "Actions" }
          ],
          rows: casesRows
        })
      }}
    </div>
  </div>
{% endblock %}
