{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "components/macros/apiErrors/inset.njk" import apiErrorInset %}

{%- macro referralHistoryTable(context) -%}
  <div class="govuk-summary-card">
    <div class="govuk-summary-card__title-wrapper">
      <h2 class="govuk-summary-card__title">Referral history</h2>
    </div>
    <div class="govuk-summary-card__content">
      {% if context.hasApiError %}
        {{ apiErrorInset() }}
      {% else %}
        {% if (context.rows | length > 0) %}
          <div class="govuk-summary-list">
            {{
              govukTable({
                    classes: 'sas-table',
                firstCellIsHeader: true,
                head: [
                  { text: "Referral type" },
                  { text: "Referred by" },
                  { text: "Status and details" },
                  { html: '<span class="govuk-visually-hidden">Actions</span>' }
                ],
                rows: context.rows
              })
            }}
          </div>
        {% else %}
          <p class="govuk-body">No previous referrals</p>
        {% endif %}
      {% endif %}
    </div>
  </div>
{%- endmacro -%}
