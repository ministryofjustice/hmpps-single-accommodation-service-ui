{% from "moj/components/alert/macro.njk" import mojAlert %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{%- from "components/macros/statusTag.njk" import statusTag %}

{%- macro accommodationCard(context) -%}
  {% if context %}
    {%- set startDateHtml -%}
      {% if context.startDate %}
        <p>
          {{ 'Since' if (context.startDate | date('days') < 0) else 'From' }} {{ context.startDate | date('long') }}<br />
          ({{ context.startDate | date('days for/in') }})
        </p>
      {% endif %}
    {%- endset -%}


    {%- set endDateHtml -%}
      {% if context.endDate %}
        <p>
          Until {{ context.endDate | date('long') }}<br />
          ({{ context.endDate | date('days for/in') }})
        </p>
      {% endif %}
    {%- endset -%}

    {%- if context.arrangementType === 'NO_FIXED_ABODE' -%}
      {{
        mojAlert({
          variant: "warning",
          title: "No fixed abode" if context.cardType === 'current' else "No fixed abode risk",
          showTitleAsHeading: true,
          dismissible: false,
          html: startDateHtml
        })
      }}
    {%- else -%}
      <div class="sas-card govuk-!-margin-bottom-4">
        <h3 class="govuk-heading-m">{{ 'Current' if context.cardType === 'current' else 'Next' }} accommodation</h3>

        {% if context.settledTag -%}
          <div class="govuk-!-margin-bottom-4">{{ statusTag(context.settledTag) }}</div>
        {%- endif %}

        <p>
          {{ context.name }}<br />
          <span class="govuk-hint">{{ context.address | safe }}</span>
        </p>

        {{ startDateHtml | safe }}

        {{ endDateHtml | safe }}
      </div>
    {%- endif -%}
  {% endif %}
{%- endmacro -%}
