{
  "name": "hmpps-single-accommodation-service-ui",
  "version": "0.0.1",
  "description": "HMPPS Single Accommodation Service Ui",
  "repository": "git@github.com:ministryofjustice/hmpps-single-accommodation-service-ui.git",
  "license": "MIT",
  "scripts": {
    "prepare": "hmpps-precommit-hooks-prepare",
    "watch-ts": "tsc -w",
    "build": "node esbuild/esbuild",
    "start": "node $NODE_OPTIONS dist/server.js | bunyan -o short",
    "start:dev": "node esbuild/esbuild --watch",
    "start:dev:wiremock": "npm run start-wiremock && npx ts-node wiremock/api.ts && SAS_API_URL=http://localhost:9091 npm run start:dev",
    "start-feature": " node $NODE_DEBUG_OPTION --env-file=feature.env dist/server.js | bunyan -o short",
    "start-feature:dev": "node esbuild/esbuild --watch --env feature.env",
    "start-wiremock": "docker compose -f docker-compose-test.yml up -d",
    "lint": "eslint . --cache --max-warnings 0",
    "lint-fix": "eslint . --cache --max-warnings 0 --fix",
    "typecheck": "tsc && tsc -p integration_tests",
    "test": "jest",
    "test:ci": "jest --runInBand",
    "test:client": "rm -rf tmp/pacts && rm tmp/sas-api.json && jest Client --no-coverage",
    "security_audit": "npx audit-ci --config audit-ci.json",
    "int-test": "npx playwright test",
    "int-test-ui": "npx playwright test --ui",
    "test:integration": "npm run start-wiremock && start-server-and-test start-feature http://localhost:3007/ping int-test",
    "test:integration:ui": "npm run start-wiremock && start-server-and-test start-feature:dev http://localhost:3007/ping int-test-ui",
    "int-test-init:ci": "npx playwright install",
    "test:e2e": "npx playwright test --config ./e2e/playwright.config.ts",
    "test:e2e:ui": "npm run test:e2e -- --ui",
    "clean": "rm -rf dist test_results",
    "rebuild": "npm run clean && npm i && npm run build",
    "generate-types": "script/generate-types",
    "setup": "npm ci && hmpps-npm-script-run-allowlist"
  },
  "engines": {
    "node": "^24",
    "npm": "^11"
  },
  "jest": {
    "preset": "ts-jest",
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest"
      ]
    },
    "collectCoverage": true,
    "collectCoverageFrom": [
      "server/**/*.{ts,js,jsx,mjs}",
      "!server/middleware/*.ts"
    ],
    "testMatch": [
      "<rootDir>/(server|job)/**/?(*.)(cy|test).{ts,js,jsx,mjs}"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/server/testutils/jest.setup.ts"
    ],
    "testEnvironment": "node",
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "test_results/jest/"
        }
      ],
      [
        "./node_modules/jest-html-reporter",
        {
          "outputPath": "test_results/unit-test-reports.html"
        }
      ]
    ],
    "moduleFileExtensions": [
      "web.js",
      "js",
      "json",
      "node",
      "ts"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.1033.0",
    "@faker-js/faker": "^9.9.0",
    "@ministryofjustice/frontend": "^7.1.1",
    "@ministryofjustice/hmpps-auth-clients": "^1.0.2",
    "@ministryofjustice/hmpps-monitoring": "^1.0.2",
    "@ministryofjustice/hmpps-npm-script-allowlist": "0.0.4",
    "@ministryofjustice/hmpps-probation-frontend-components": "1.0.2",
    "@ministryofjustice/hmpps-rest-client": "^1.2.0",
    "@pact-foundation/pact": "^16.3.0",
    "@pactflow/openapi-pact-comparator": "^1.14.0",
    "@playwright/test": "^1.59.1",
    "accessible-autocomplete": "3.0.1",
    "applicationinsights": "^2.9.8",
    "body-parser": "^2.2.2",
    "bunyan": "^1.8.15",
    "bunyan-format": "^0.2.1",
    "compression": "^1.8.1",
    "connect-flash": "^0.1.1",
    "connect-redis": "^9.0.0",
    "csrf-sync": "^4.2.1",
    "dotenv": "17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "govuk-frontend": "^6.1.0",
    "helmet": "^8.1.0",
    "http-errors": "^2.0.1",
    "jest-pact": "^0.13.0",
    "jwt-decode": "^4.0.0",
    "nocache": "^4.0.0",
    "nunjucks": "^3.2.4",
    "openapi-typescript-codegen": "^0.30.0",
    "passport": "^0.7.0",
    "passport-oauth2": "^1.8.0",
    "path-to-regexp": "8.4.2",
    "redis": "^5.12.1",
    "static-path": "0.0.4",
    "superagent": "^10.3.0"
  },
  "devDependencies": {
    "@jgoz/esbuild-plugin-typecheck": "^4.0.4",
    "@ministryofjustice/eslint-config-hmpps": "^1.0.3",
    "@ministryofjustice/hmpps-precommit-hooks": "2.0.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/bunyan": "^1.8.11",
    "@types/bunyan-format": "^0.2.9",
    "@types/compression": "^1.8.1",
    "@types/connect-flash": "0.0.40",
    "@types/express-session": "^1.19.0",
    "@types/http-errors": "^2.0.5",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.2",
    "@types/nunjucks": "^3.2.6",
    "@types/passport": "^1.0.17",
    "@types/passport-oauth2": "^1.8.0",
    "@types/superagent": "^8.1.9",
    "@types/supertest": "^7.2.0",
    "audit-ci": "^7.1.0",
    "aws-sdk-client-mock": "^4.1.0",
    "esbuild": "^0.28.0",
    "esbuild-plugin-clean": "^1.0.1",
    "esbuild-plugin-copy": "^2.1.1",
    "esbuild-plugin-manifest": "^1.0.5",
    "esbuild-sass-plugin": "^3.7.0",
    "fishery": "^2.4.0",
    "jest": "30.3.0",
    "jest-html-reporter": "^4.4.0",
    "jest-junit": "17.0.0",
    "jest-mock-extended": "^4.0.1",
    "jsonwebtoken": "^9.0.3",
    "lint-staged": "^16.4.0",
    "nock": "^14.0.13",
    "prettier": "^3.8.3",
    "prettier-plugin-jinja-template": "^2.1.0",
    "start-server-and-test": "^3.0.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  }
}
