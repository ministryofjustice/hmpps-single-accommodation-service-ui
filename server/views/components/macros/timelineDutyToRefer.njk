{%- from "components/macros/statusTag.njk" import statusTag %}

{%- macro timelineDutyToRefer(context) -%}
  {% if context.status %}
    <p>{{ statusTag(context.status) }}</p>
  {% endif %}

  {% for item in context.values %}
    {% if not item.isList and item.value %}
      {% if item.showLabel %}
        <p class="govuk-!-margin-bottom-1">{{ item.label }}: {{ item.value }}</p>
      {% else %}
        <p class="govuk-!-margin-bottom-4">{{ item.value }}</p>
      {% endif %}
    {% endif %}
  {% endfor %}
  {% if context.hasListItems %}
    <ul class="govuk-list govuk-list--bullet govuk-!-margin-bottom-0">
      {% for item in context.values %}
        {% if item.isList and item.value %}
          <li>{{ item.label }} changed to: {{ item.value }}</li>
        {% endif %}
      {% endfor %}
    </ul>
  {% endif %}
{%- endmacro -%}
