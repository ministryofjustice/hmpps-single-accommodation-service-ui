{% extends "pages/duty-to-refer/layout.njk" %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{% set skipLinkText = 'Skip this for now' %}

{% block formContent %}
  <input type="hidden" name="currentStatus" value="{{ dtr.status }}" />
  <input type="hidden" name="submissionDate" value="{{ dtr.submission.submissionDate }}" />
  <input type="hidden" name="localAuthorityAreaId" value="{{ dtr.submission.localAuthority.localAuthorityAreaId }}" />
  <input type="hidden" name="referenceNumber" value="{{ dtr.submission.referenceNumber }}" />

  {{
    govukRadios({
        id: "outcomeReason",
        name: "outcomeReason",
        fieldset: {
            legend: {
                text: "Did the local authority agreed to support this request for housing?",
                classes: "govuk-fieldset__legend--s"
            }
        },
        items: outcomeItems,
        errorMessage: errors.outcomeReason
    })
  }}
{% endblock %}
