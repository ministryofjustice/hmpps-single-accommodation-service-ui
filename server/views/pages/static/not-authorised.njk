{% extends "./layout.njk" %}

{% set pageTitle = "Not authorised" %}

{% block govukHeader %}
  {% if user %}
    {{ super() }}
  {% else %}
    {% include "partials/header.njk" %}
  {% endif %}
{% endblock %}

{% block govukFooter %}
  {% if user %}
    {{ super() }}
  {% else %}
    {% include "partials/footer.njk" %}
  {% endif %}
{% endblock %}

{% block staticContent %}
  <h1 class="govuk-heading-l">You do not have permission to access the {{ applicationName }} service</h1>
  {% if user and user.username %}
    <p>You are signed in as {{ user.username }}.</p>
  {% endif %}
  <p>If you are signed in with the wrong account, sign out and try again.</p>
  <h2 class="govuk-heading-m">Get access</h2>
  <p>
    Request permission in the
    <a href="{{ supportLinks.accessRequest }}" class="govuk-link govuk-link--no-visited-state">
      Accommodation service Private Beta Teams channel
    </a>
    if you think you should have access to this service.
  </p>
{% endblock %}
