{% from "govuk/components/input/macro.njk" import govukInput %}
{% extends "pages/proposed-address/layout.njk" %}

{% set pageTitle = "Find an address" %}
{% set backLinkHref = paths.cases.show({crn: crn}) %}
{% set formAction = paths.proposedAddresses.lookup({crn: crn}) %}
{% set buttonText = 'Find address' %}
{% set hideManualAddressEntry = featureFlags.hideManualAddressEntry %}

{% block extraAction %}
  {% if not hideManualAddressEntry %}
    <p>
      <a class="govuk-link govuk-link--no-visited-state" href="{{ paths.proposedAddresses.details({ crn: crn }) }}">
        Enter address manually
      </a>
    </p>
  {% endif %}
{% endblock %}

{% block formContent %}
  <legend class="govuk-fieldset__legend govuk-fieldset__legend--l">
    <h1 class="govuk-fieldset__heading">Find an address</h1>
  </legend>

  {% if not hideManualAddressEntry %}
    <p>If it does not have a UK postcode, select 'Enter address manually'.</p>
  {% endif %}

  {{
    govukInput({
      label: {
        text: 'Property name or number'
      },
      hint: {
        text: 'For example, 116, The Mill or Flat 37a'
      },
      classes: 'govuk-input--width-20',
      name: 'nameOrNumber',
      id: 'nameOrNumber',
      value: nameOrNumber,
      errorMessage: errors.nameOrNumber
    })
  }}

  {{
    govukInput({
      label: {
        text: 'UK postcode'
      },
      classes: 'govuk-input--width-10',
      name: 'postcode',
      id: 'postcode',
      value: postcode,
      errorMessage: errors.postcode
    })
  }}
{% endblock %}
