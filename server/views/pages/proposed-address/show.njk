{% extends "partials/layout.njk" %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "moj/components/timeline/macro.njk" import mojTimeline %}
{% from "components/macros/errorSummary.njk" import showErrorSummary %}
{% from "components/macros/caseDetails.njk" import caseDetails %}

{% set pageTitle = applicationName + " - Proposed address" %}
{% set mainClasses = "sas-profile-page" %}

{% block beforeContent %}
  {{
    govukBreadcrumbs({
      items: [
        {
          text: "Case list",
          href: "/"
        },
        {
          text: caseData.name + "'s profile",
          href: paths.cases.show({ crn: caseData.crn })
        }
      ]
    })
  }}
  {{ super() }}
{% endblock %}

{% block content %}
  {{ showErrorSummary(errorSummary) }}

  {{ caseDetails(caseData, assignedTo) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds-from-desktop">
      <h1 class="govuk-heading-l govuk-!-margin-top-4">{{ address }}</h1>
    </div>
  </div>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds-from-desktop">
      <section>
        <h2 class="govuk-heading-m">Address details</h2>

        {{
          govukSummaryList({
            rows: addressDetailRows
          })
        }}

        {% if nextAction %}
          {{ govukButton(nextAction) }}
        {% endif %}
      </section>

      <section class="govuk-!-margin-top-8 govuk-!-margin-bottom-4">
        <form action="{{ currentUrl }}" method="post">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

          {{
            govukTextarea({
              name: "note",
              label: {
                text: "Add note",
                classes: "govuk-label--s"
              },
              classes: "govuk-!-width-two-thirds",
              value: note,
              errorMessage: errors.note
            })
          }}

          {{
            govukButton({
              text: "Add note",
              preventDoubleClick: true,
              classes: "govuk-button--secondary"
            })
          }}
        </form>
      </section>
    </div>

    <section class="govuk-grid-column-one-third-from-desktop">
      <h2 class="govuk-heading-m">Events and notes timeline</h2>

      {{
        mojTimeline({
          headingLevel: 3,
          items: timeline
        })
      }}
    </section>
  </div>
{% endblock %}
