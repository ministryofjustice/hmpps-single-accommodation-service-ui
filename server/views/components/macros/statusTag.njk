{%- macro statusTag(status) -%}
  <strong class="govuk-tag{{ ' govuk-tag--' + status.colour if status.colour }}">{{ status.text }}</strong>
  {%- if status.date %}
    <p class="govuk-hint govuk-!-margin-top-2">
      From {{ status.date | date }}
      <br/>
      ({{ status.date | date('days for/in') }})
    </p>
  {%- endif %}
{%- endmacro -%}
