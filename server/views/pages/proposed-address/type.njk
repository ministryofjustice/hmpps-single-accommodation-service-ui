{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/input/macro.njk" import govukInput %}

{% extends "pages/proposed-address/layout.njk" %}

{% set pageTitle = "Which best describes the living arrangement for the person at this address?  " + applicationName %}
{% set formAction = paths.proposedAddresses.type({crn: crn}) %}

{% block formContent %}
  {{ govukRadios({
      name: "accommodationTypeCode",
      fieldset: {
          legend: {
              text: "Which best describes the living arrangement for " + name + " at this address?",
              classes: "govuk-fieldset__legend--l"
          }
      },
      items: accommodationTypeItems,
      errorMessage: errors.accommodationTypeCode
  }) }}
{% endblock %}
