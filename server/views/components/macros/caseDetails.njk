{% from "components/macros/riskLevelTag.njk" import riskLevelTag %}
{% from "components/macros/tierScoreTag.njk" import tierScoreTag %}

{% macro caseDetails(caseData, assignedTo) %}
  <header class="sas-profile-header">
    {# <img class="sas-profile-image" alt="Photo of {{ caseData.name }}" src=""> #}
    <div>
      <h1 class="govuk-heading-l govuk-!-margin-bottom-2">
        {{ caseData.name }}
      </h1>
      <dl class="sas-risk-tags govuk-!-margin-0 govuk-!-margin-bottom-2">
        {{ riskLevelTag(caseData.riskLevel) }}

        {{ tierScoreTag(caseData.tierScore) }}
      </dl>
      <div class="govuk-body-s govuk-!-margin-bottom-0">
        <dl class="sas-profile-header__details govuk-!-margin-bottom-1">
          <dt>CRN</dt>
          <dd>{{ caseData.crn }}</dd>
          {% if caseData.prisonNumber -%}
            <dt>Prison number</dt>
            <dd>{{ caseData.prisonNumber }}</dd>
          {%- endif %}
          <dt>PNC reference</dt>
          <dd>{{ caseData.pncReference }}</dd>
        </dl>
      </div>
      <div class="govuk-body-s govuk-!-margin-bottom-0">
        <dl class="sas-profile-header__details govuk-!-margin-bottom-1">
          <dt>Date of birth</dt>
          <dd>{{ caseData.dateOfBirth | date }} ({{ caseData.dateOfBirth | date('age') }})</dd>
          <dt>Assigned to</dt>
          <dd>{{ assignedTo }}</dd>
        </dl>
      </div>
    </div>
  </header>
{% endmacro %}
