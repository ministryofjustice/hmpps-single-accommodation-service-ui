{% extends "govuk/template.njk" %}

{% from "govuk/components/phase-banner/macro.njk" import govukPhaseBanner %}

{% block head %}
  {% include "./applicationInsightsScript.njk" %}

  {% for css in feComponents.cssIncludes %}
      <link href="{{ css }}" nonce="{{ cspNonce }}" rel="stylesheet" />
  {% endfor %}
  <link href="{{ '/assets/css/index.css' | assetMap }}" rel="stylesheet"/>
{% endblock %}

{% block pageTitle %}{{ "Error: " if errorSummary | length }}{{ pageTitle }}{{ ' - ' if pageTitle }}{{ applicationName }}{% endblock %}

{% block govukHeader %}
  {{ feComponents.header | safe }}
  <section aria-label="Service information" class="govuk-service-navigation"
    data-module="govuk-service-navigation">
    <div class="govuk-width-container">
      <div class="govuk-service-navigation__container">
        <span class="govuk-service-navigation__service-name">
          <a href="/" class="govuk-service-navigation__link">
            {{ applicationName }}
          </a>
        </span>
      </div>
    </div>
  </section>

  {% set phaseBannerHtml %}
    Help us improve the Accommodation service. <a href="{{ supportLinks.feedbackForm }}" target="_blank" rel="noreferrer noopener">Complete this survey (opens in new tab)</a>
  {% endset %}

  {{ govukPhaseBanner({
    tag: {
      text: "Pilot"
    },
    html: phaseBannerHtml
  }) }}
{% endblock %}

{% block bodyStart %}{% endblock %}

{% block containerStart %}
  {% include "components/_messages.njk" %}
{% endblock %}

{% block containerEnd %}
  {% include "components/_reportBanner.njk" %}
{% endblock %}

{% block govukFooter %}
  {{ feComponents.footer | safe }}
{% endblock %}

{% block bodyEnd %}
  <script type="module" src="{{ '/assets/js/index.js' | assetMap }}"></script>
{% endblock %}

{% block extraScripts %}
  {% for js in feComponents.jsIncludes %}
      <script src="{{ js }}" nonce="{{ cspNonce }}"></script>
  {% endfor %}
{% endblock %}
